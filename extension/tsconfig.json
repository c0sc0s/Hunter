{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../.tsbuild/extension",
    "tsBuildInfoFile": "../.tsbuild/extension.tsbuildinfo",
    "allowJs": false,
    "baseUrl": "..",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {},
    "types": ["chrome", "node"],
    "jsx": "preserve"
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "references": [{ "path": "../shared" }]
}
