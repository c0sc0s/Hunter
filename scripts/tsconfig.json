{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "..",
    "outDir": "../.tsbuild/scripts",
    "tsBuildInfoFile": "../.tsbuild/scripts.tsbuildinfo",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  },
  "include": ["*.ts", "../vite.config.ts"],
  "references": [{ "path": "../shared" }, { "path": "../server" }]
}
