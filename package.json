{
  "name": "huntter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "node dist-server/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harness:init": "tsx scripts/harness-init.ts",
    "smoke:api": "tsx scripts/smoke-api.ts",
    "golden:browser": "tsx scripts/golden-browser.ts",
    "golden:extension": "tsx scripts/golden-extension.ts",
    "golden:visual": "tsx scripts/golden-visual.ts",
    "golden:visual:update": "tsx scripts/golden-visual.ts --update-baselines",
    "test": "pnpm test:url && pnpm test:metadata && pnpm test:timing && pnpm test:capture-events && pnpm test:capture-input && pnpm test:quality && pnpm test:signals && pnpm test:html && pnpm test:html-fetch && pnpm test:cover && pnpm test:contract && pnpm test:recognition && pnpm test:source-contracts && pnpm test:extension && pnpm test:repository",
    "test:url": "tsx server/tests/url.test.ts",
    "test:metadata": "tsx server/tests/recognitionMetadata.test.ts",
    "test:timing": "tsx server/tests/recognitionTiming.test.ts",
    "test:capture-events": "tsx server/tests/captureEvents.test.ts",
    "test:capture-input": "tsx server/tests/captureInput.test.ts",
    "test:quality": "tsx server/tests/contentQuality.test.ts",
    "test:signals": "tsx server/tests/contentSignals.test.ts",
    "test:html": "tsx server/tests/contentHtml.test.ts",
    "test:html-fetch": "tsx server/tests/htmlFetch.test.ts",
    "test:cover": "tsx server/tests/coverImage.test.ts",
    "test:contract": "tsx server/tests/extractedContentContract.test.ts",
    "test:recognition": "tsx server/tests/recognition.test.ts",
    "test:source-contracts": "tsx server/tests/sourceContracts.test.ts",
    "test:extension": "tsx extension/tests/extractor.test.ts",
    "test:repository": "tsx server/tests/sqliteRepository.test.ts",
    "verify": "pnpm harness:init && pnpm check && pnpm lint && pnpm format:check && pnpm test && pnpm smoke:api && pnpm golden:browser && pnpm golden:extension && pnpm golden:visual && pnpm build",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "defuddle": "^0.18.1",
    "dompurify": "^3.4.7",
    "express": "^4.19.2",
    "jsdom": "^24.1.1",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.3"
  }
}
